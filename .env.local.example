# Frontend (must be VITE_ prefixed to reach the client bundle)
VITE_CLERK_PUBLISHABLE_KEY=
VITE_RESONANCE_API_URL=

# Server-only — read by api/liveblocks-auth.ts. Never prefix VITE_.
CLERK_SECRET_KEY=
LIVEBLOCKS_SECRET_KEY=

# TMDB v3 Read Access Token (the JWT, NOT the v3 API key — two different
# credentials; get it from themoviedb.org/settings/api under "API Read
# Access Token"). Read by api/tmdb.ts only; never exposed to the bundle.
TMDB_API_KEY=
